#!/bin/bash
python3 -c 'import os; f=lambda v,c: sum(c.index(x)*len(c)**i for i,x in enumerate(v[::-1])); n=f(os.environ.get("WATER",""),"water")+f(os.environ.get("STIR",""),"stir."); b="bestchol"; d=list(); [d.insert(0,b[n%8]) or globals().update(n=n//8) for _ in range(100) if n]; print("".join(d))'
